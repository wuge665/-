{
  "name": "科技简报",
  "version": "1.0",
  "description": "科技前沿资讯自动发布系统",
  "sources": {
    "hackernoon": {
      "name": "HackerNoon",
      "type": "rss",
      "url": "https://hackernoon.com/feed",
      "enabled": true,
      "priority": 1
    },
    "wired": {
      "name": "Wired",
      "type": "rss",
      "url": "https://www.wired.com/feed/rss",
      "enabled": true,
      "priority": 2
    },
    "mit_tech": {
      "name": "MIT Tech",
      "type": "rss",
      "url": "https://www.technologyreview.com/feed/",
      "enabled": true,
      "priority": 3
    }
  },
  "filters": {
    "exclude_domains": [
      "mp.weixin.qq.com",
      "weixin.qq.com",
      "weixindubai.com"
    ],
    "exclude_keywords": [
      "广告",
      "招聘",
      "优惠券",
      "促销",
      "限时",
      "免费领取"
    ],
    "high_weight_keywords": [
      "大模型", "LLM", "GPT", "AI", "AGI", "模型",
      "ChatGPT", "Gemini", "Claude", "Sora", "Grok",
      "自动驾驶", "机器人", "量子计算", "AI Agent",
      "OpenAI", "Google", "Anthropic", "Meta", "xAI",
      "DeepSeek", "Kimi", "Llama", "Qwen", "Mistral",
      "o1", "推理", "多模态", "AI编程", "Cursor", "Claude Code"
    ],
    "min_title_length": 15,
    "max_title_length": 80,
    "max_articles_per_source": 10,
    "output_count": 5
  },
  "style": {
    "persona": "科技媒体编辑",
    "tone": "自然、活泼、有特色",
    "max_content_length": 0
  },
  "publish": {
    "post_as_draft": true,
    "notify_on_complete": false
  }
}