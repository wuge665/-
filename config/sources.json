  "filters": {
    "exclude_domains": [
      "mp.weixin.qq.com",
      "weixin.qq.com",
      "weixindubai.com"
    ],
    "exclude_keywords": [
      "广告",
      "招聘",
      "优惠券",
      "促销",
      "限时",
      "免费领取"
    ],
    "high_weight_keywords": [
      "大模型", "LLM", "GPT", "AI", "AGI", "模型",
      "ChatGPT", "Gemini", "Claude", "Sora", "Grok",
      "自动驾驶", "机器人", "量子计算", "AI Agent",
      "OpenAI", "Google", "Anthropic", "Meta", "xAI",
      "DeepSeek", "Kimi", "Llama", "Qwen", "Mistral",
      "o1", "推理", "多模态", "AI编程", "Cursor", "Claude Code",
      "工具", "教程", "使用", "指南", "测评", "评测",
      "硬件", "芯片", "GPU", "CPU", "设备", "产品发布",
      "开源", "新功能", "更新", "版本", "配置", "安装"
    ],
    "include_keywords": [
      "AI tool", "tutorial", "guide", "review", "setup", "install",
      "hardware", "chip", "GPU", "device", "innovation",
      "how to", "use", "beginner", "getting started",
      "测评", "教程", "工具", "硬件", "创新"
    ],
    "min_title_length": 15,
    "max_title_length": 80,
    "max_articles_per_source": 15,
    "output_count": 20,
    "prefer_with_images": true,
    "prefer_ai_tools": true,
    "prefer_hardware": true
  },
  "style": {
    "persona": "科技媒体编辑",
    "tone": "自然、活泼、有特色",
    "max_content_length": 0
  },
  "publish": {
    "post_as_draft": true,
    "notify_on_complete": false
  }
}