# 微信公众号配置
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret

# AI API配置
# Claude API
ANTHROPIC_API_KEY=your_anthropic_key

# Kimi API (备选)
MOONSHOT_API_KEY=your_kimi_key

# 或者使用 OpenAI
OPENAI_API_KEY=your_openai_key

# 系统配置
ARTICLES_COUNT=5
POST_AS_DRAFT=true  # true=草稿箱, false=直接发布

# 资讯源配置
NEWS_SOURCES=techcrunch,hackernews,36kr,arxiv

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/brief_{date}.log